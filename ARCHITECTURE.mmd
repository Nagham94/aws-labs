flowchart TD
  subgraph VPC["VPC (192.168.0.0/16)"]
    IGW["Internet Gateway"]
    PUB1["Public Subnet AZ1\n192.168.1.0/24"]
    PUB2["Public Subnet AZ2\n192.168.3.0/24"]
    PRI["Private Subnet\n192.168.2.0/24"]
  end

  ALB["Application Load Balancer (ALB)"]
  ALB_SG["ALB Security Group\nAllow HTTP 80"]
  TG["Target Group\nHTTP 80"]
  EC2["EC2 Web Server + EBS"]
  ASG["Auto Scaling Group"]
  LT["Launch Template"]
  ECS["ECS EC2 Instance + Nginx Service"]
  RDS["RDS MySQL Instance"]
  S3["S3 Website Bucket"]
  IAM["IAM User + Start/Stop Policy"]

  IGW --> PUB1
  IGW --> PUB2
  IGW --> PRI

  PUB1 --> ALB
  PUB1 --> EC2
  PUB1 --> ECS
  PUB1 --> ASG
  PUB2 --> RDS
  PRI --> RDS

  ALB_SG --> ALB
  ALB --> TG
  TG --> EC2
  TG --> ASG
  LT --> ASG

  IAM --> EC2
  IAM --> ASG
  IAM --> ECS

  S3 -.-> PUB1

  classDef awsNode fill:#f7f7f7,stroke:#333,stroke-width:1px;
  class VPC,IGW,PUB1,PUB2,PRI,ALB,ALB_SG,TG,EC2,ASG,LT,ECS,RDS,S3,IAM awsNode;
